CB_HOST=couchbase://localhost
CB_USERNAME=Administrator
CB_PASSWORD=password
CB_BUCKET=mybucket
DJANGO_SECRET_KEY=change-me-in-production

# Sign in with Apple — required for account-deletion token revocation
# (App Store guideline 5.1.1(v)). Get these from App Store Connect:
#   TEAM_ID    : Membership page → Team ID
#   KEY_ID     : Keys → create a "Sign in with Apple" key (10-char ID)
#   PRIVATE_KEY: contents of the .p8 file (use \n for newlines in env)
#   APP_ID     : app bundle identifier (same as iOS CFBundleIdentifier)
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_APP_ID=com.brewsync.app
APPLE_CLIENT_ID=com.brewsync.auth

# Google Sign-In — OAuth client ID for the iOS app
GOOGLE_IOS_CLIENT_ID=
